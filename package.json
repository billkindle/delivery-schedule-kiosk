{
  "name": "delivery-schedule-kiosk",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "start": "node server/index.js",
    "audit": "npm audit",
    "audit:ci": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "dotenv": "16.6.1",
    "express": "4.22.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "5.1.4",
    "autoprefixer": "10.5.0",
    "concurrently": "8.2.2",
    "postcss": "8.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.19",
    "vite": "6.4.3"
  }
}
